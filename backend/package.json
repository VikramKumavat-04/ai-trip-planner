{
  "name": "ai-trip-planner-backend",
  "version": "1.0.0",
  "description": "AI Trip Planner Backend API",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd ../frontend && npm install && npm run build && cp -r dist ../backend/public",
    "render-build": "npm install && cd ../frontend && npm install --legacy-peer-deps && npm run build && cp -r dist ../backend/public"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "nodemon": "^3.0.2",
    "uuid": "^9.0.1",
    "xss": "^1.0.15"
  }
}
